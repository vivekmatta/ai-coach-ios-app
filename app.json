{
  "expo": {
    "name": "AI Coach",
    "slug": "ai-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F7F5F1"
    },
    "plugins": [
      "expo-audio",
      "expo-notifications"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Coach uses the microphone to attach voice notes to your daily coach context."
      }
    }
  }
}
